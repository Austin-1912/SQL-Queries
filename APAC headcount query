## **Step 2: Add Customer Master GH Flag to Each Customer-Level Table**

### **Modified Script for EMAIL/SMS/WEBHOOK Stream:**

```sql
CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_EMAIL_SMS_WH_CUST_LEVEL AS
SELECT
    sh.customer_key,
    sh.RELEASE_2_VENDOR_DATE AS CAMPAIGN_DATE,
    sh.CAMPAIGN_DESC AS CAMPAIGN_NAME,
    CASE 
        WHEN SUBSTR(sh.activity_code,3,1) = 'E' THEN 'EMAIL'
        WHEN SUBSTR(sh.activity_code,3,1) = 'S' THEN 'SMS' 
        WHEN SUBSTR(sh.activity_code,3,1) = 'W' THEN 'WHATSAPP' 
    END AS CHANNEL_TYPE,
    
    -- Campaign assignment flags
    CASE WHEN SUBSTR(sh.activity_code,1,1) = 'S' THEN 1 ELSE 0 END AS IS_TEST_IN_CAMPAIGN,
    CASE WHEN SUBSTR(sh.activity_code,1,1) = 'C' THEN 1 ELSE 0 END AS IS_CONTROL_IN_CAMPAIGN,
    CASE WHEN SUBSTR(sh.activity_code,1,1) = 'G' THEN 1 ELSE 0 END AS IS_GH_IN_CAMPAIGN,
    
    -- Customer Master GH flag (add this)
    COALESCE(cm.GLOBAL_HOLDOUT_FLAG, 'N') AS IS_GH_IN_CUSTOMER_MASTER,
    
    -- Contamination flags
    CASE 
        WHEN SUBSTR(sh.activity_code,1,1) = 'S' AND COALESCE(cm.GLOBAL_HOLDOUT_FLAG, 'N') = 'Y' 
        THEN 1 ELSE 0 
    END AS CONTAMINATION_TEST_BUT_GH_IN_CM,
    
    CASE 
        WHEN SUBSTR(sh.activity_code,1,1) = 'C' AND COALESCE(cm.GLOBAL_HOLDOUT_FLAG, 'N') = 'Y' 
        THEN 1 ELSE 0 
    END AS CONTAMINATION_CONTROL_BUT_GH_IN_CM,
    
    CASE 
        WHEN SUBSTR(sh.activity_code,1,1) = 'G' AND COALESCE(cm.GLOBAL_HOLDOUT_FLAG, 'N') = 'N' 
        THEN 1 ELSE 0 
    END AS CONTAMINATION_GH_BUT_NOT_IN_CM

FROM "WUDNA"."SUMMARY_GEN"."WUDNA_SOLICITATION_HISTORY_VW" sh

-- JOIN to Customer Master
LEFT JOIN "WUDNA"."SUMMARY_GEN"."WUDNA_CUSTOMER_MASTER_VW" cm
    ON sh.customer_key = cm.customer_key

WHERE
    NOT UPPER(sh.CAMPAIGN_DESC) ILIKE ANY ('%FULFILLMENT%','%STAGE_%','STGE_%','TEST%','%WUPLUS%','%LIFECYCLE_ONBOARDING_CTADIGITAL_WP%','%UNKNOWN%','%APOLOGY%','%SURVEY%','%RCVX%','UAT%','%SERVICE%')
    AND DATE(sh.RELEASE_2_VENDOR_DATE) >= '2026-01-01'
    AND DATE(sh.RELEASE_2_VENDOR_DATE) < DATE_TRUNC('MONTH', CURRENT_DATE());
```

