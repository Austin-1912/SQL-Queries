  MODE(CASE WHEN datediff(MINUTE,e.record_datetime,event_captured_dt) > 0 AND datediff(MINUTE,e.record_datetime,event_captured_dt) <= 262080 THEN PRICING_CHANNEL END) AS R6_CHANNEL,     //Churn_reduction_metric
