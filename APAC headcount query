-- ============================================================================
-- STEP 8: TOP CORRIDORS COMPARISON
-- ============================================================================
-- Purpose: Compare pricing for the top 10 corridors
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_CASH_VS_APN_TOP_CORRIDORS AS
WITH top_corridors AS (
    SELECT 
        CONCAT(SNDCOUNTRY_CODE, '-', RCVCOUNTRY_CODE) AS CORRIDOR,
        COUNT(DISTINCT TXN_ID) AS txn_count
    FROM WUDNA.SUMMARY_GEN.WUDNA_TXN_MASTER_ANALYTICS_VW
    WHERE SNDCOUNTRY_CODE = 'US'
        AND DATE(rcvpaying_datetime) >= '2025-02-01'
        AND DATE(rcvpaying_datetime) < '2026-02-01'
        AND PAYOUT_TYPE IN ('ACCOUNT', 'CASH')
    GROUP BY CORRIDOR
    ORDER BY txn_count DESC
    LIMIT 10
)
SELECT
    txn.PAYOUT_TYPE,
    CONCAT(txn.SNDCOUNTRY_CODE, '-', txn.RCVCOUNTRY_CODE) AS CORRIDOR,
    
    COUNT(DISTINCT txn.TXN_ID) AS TOTAL_TXNS,
    
    AVG(txn.SNDPRINCIPAL_USD) AS AVG_PRINCIPAL,
    AVG(txn.REVENUE) AS AVG_REVENUE,
    AVG(txn.FEE) AS AVG_FEE,
    AVG(txn.FX_MARGIN) AS AVG_FX_MARGIN,
    
    AVG(txn.REVENUE / NULLIF(txn.SNDPRINCIPAL_USD, 0) * 100) AS AVG_REVENUE_PCT,
    AVG(txn.FEE / NULLIF(txn.SNDPRINCIPAL_USD, 0) * 100) AS AVG_FEE_PCT

FROM WUDNA.SUMMARY_GEN.WUDNA_TXN_MASTER_ANALYTICS_VW txn
INNER JOIN top_corridors tc
    ON CONCAT(txn.SNDCOUNTRY_CODE, '-', txn.RCVCOUNTRY_CODE) = tc.CORRIDOR
WHERE txn.SNDCOUNTRY_CODE = 'US'
    AND DATE(txn.rcvpaying_datetime) >= '2025-02-01'
    AND DATE(txn.rcvpaying_datetime) < '2026-02-01'
    AND txn.PAYOUT_TYPE IN ('ACCOUNT', 'CASH')
GROUP BY txn.PAYOUT_TYPE, CORRIDOR
ORDER BY CORRIDOR, txn.PAYOUT_TYPE;

-- Verification Query
SELECT * FROM CAM_1746_CASH_VS_APN_TOP_CORRIDORS
ORDER BY CORRIDOR, PAYOUT_TYPE;


-- ============================================================================
-- STEP 9: SUMMARY COMPARISON VIEW
-- ============================================================================
-- Purpose: Side-by-side comparison for easy Excel export
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_CASH_VS_APN_SUMMARY_PIVOT AS
WITH cash_data AS (
    SELECT
        'CASH' AS payout_type,
        COUNT(DISTINCT SNDCUSTOMER_KEY) AS customers,
        COUNT(DISTINCT TXN_ID) AS txns,
        AVG(SNDPRINCIPAL_USD) AS avg_principal,
        AVG(REVENUE) AS avg_revenue,
        AVG(FEE) AS avg_fee,
        AVG(FX_MARGIN) AS avg_fx,
        AVG(REVENUE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS revenue_pct,
        AVG(FEE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS fee_pct
    FROM WUDNA.SUMMARY_GEN.WUDNA_TXN_MASTER_ANALYTICS_VW
    WHERE SNDCOUNTRY_CODE = 'US'
        AND DATE(rcvpaying_datetime) >= '2025-02-01'
        AND DATE(rcvpaying_datetime) < '2026-02-01'
        AND PAYOUT_TYPE = 'CASH'
        AND SNDCUSTOMER_KEY IS NOT NULL
),
account_data AS (
    SELECT
        'ACCOUNT' AS payout_type,
        COUNT(DISTINCT SNDCUSTOMER_KEY) AS customers,
        COUNT(DISTINCT TXN_ID) AS txns,
        AVG(SNDPRINCIPAL_USD) AS avg_principal,
        AVG(REVENUE) AS avg_revenue,
        AVG(FEE) AS avg_fee,
        AVG(FX_MARGIN) AS avg_fx,
        AVG(REVENUE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS revenue_pct,
        AVG(FEE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS fee_pct
    FROM WUDNA.SUMMARY_GEN.WUDNA_TXN_MASTER_ANALYTICS_VW
    WHERE SNDCOUNTRY_CODE = 'US'
        AND DATE(rcvpaying_datetime) >= '2025-02-01'
        AND DATE(rcvpaying_datetime) < '2026-02-01'
        AND PAYOUT_TYPE = 'ACCOUNT'
        AND SNDCUSTOMER_KEY IS NOT NULL
)
SELECT
    'Customers' AS metric,
    c.customers AS cash_value,
    a.customers AS account_value,
    a.customers - c.customers AS difference,
    ROUND((a.customers - c.customers) * 100.0 / NULLIF(c.customers, 0), 2) AS pct_difference
FROM cash_data c, account_data a

UNION ALL

SELECT
    'Transactions' AS metric,
    c.txns AS cash_value,
    a.txns AS account_value,
    a.txns - c.txns AS difference,
    ROUND((a.txns - c.txns) * 100.0 / NULLIF(c.txns, 0), 2) AS pct_difference
FROM cash_data c, account_data a

UNION ALL

SELECT
    'Avg Principal (PPT)' AS metric,
    c.avg_principal AS cash_value,
    a.avg_principal AS account_value,
    a.avg_principal - c.avg_principal AS difference,
    ROUND((a.avg_principal - c.avg_principal) * 100.0 / NULLIF(c.avg_principal, 0), 2) AS pct_difference
FROM cash_data c, account_data a

UNION ALL

SELECT
    'Avg Revenue (RPT)' AS metric,
    c.avg_revenue AS cash_value,
    a.avg_revenue AS account_value,
    a.avg_revenue - c.avg_revenue AS difference,
    ROUND((a.avg_revenue - c.avg_revenue) * 100.0 / NULLIF(c.avg_revenue, 0), 2) AS pct_difference
FROM cash_data c, account_data a

UNION ALL

SELECT
    'Avg Fee' AS metric,
    c.avg_fee AS cash_value,
    a.avg_fee AS account_value,
    a.avg_fee - c.avg_fee AS difference,
    ROUND((a.avg_fee - c.avg_fee) * 100.0 / NULLIF(c.avg_fee, 0), 2) AS pct_difference
FROM cash_data c, account_data a

UNION ALL

SELECT
    'Avg FX Margin' AS metric,
    c.avg_fx AS cash_value,
    a.avg_fx AS account_value,
    a.avg_fx - c.avg_fx AS difference,
    ROUND((a.avg_fx - c.avg_fx) * 100.0 / NULLIF(c.avg_fx, 0), 2) AS pct_difference
FROM cash_data c, account_data a

UNION ALL

SELECT
    'Revenue as % of Principal' AS metric,
    c.revenue_pct AS cash_value,
    a.revenue_pct AS account_value,
    a.revenue_pct - c.revenue_pct AS difference,
    ROUND((a.revenue_pct - c.revenue_pct) * 100.0 / NULLIF(c.revenue_pct, 0), 2) AS pct_difference
FROM cash_data c, account_data a

UNION ALL

SELECT
    'Fee as % of Principal' AS metric,
    c.fee_pct AS cash_value,
    a.fee_pct AS account_value,
    a.fee_pct - c.fee_pct AS difference,
    ROUND((a.fee_pct - c.fee_pct) * 100.0 / NULLIF(c.fee_pct, 0), 2) AS pct_difference
FROM cash_data c, account_data a;

