WHEN CHANNEL = 'C' THEN 'CONTENT CARD'
WHEN CHANNEL = 'P' THEN 'PUSH' 
WHEN CHANNEL = 'W' THEN 'WHATSAPP' END AS CHANNEL_TYPE,
CASE 
WHEN CHANNEL IN ('I','C','P') THEN 'APP'
