-- Verification Query
SELECT * FROM CAM_1746_CASH_VS_APN_BY_CORRIDOR_TYPE
ORDER BY DIRECTION, PAYOUT_TYPE;


-- ============================================================================
-- STEP 5: DETAILED REVENUE COMPOSITION BREAKDOWN
-- ============================================================================
-- Purpose: Understand the composition of revenue (Fee vs FX)
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_REVENUE_COMPOSITION AS
SELECT
    PAYOUT_TYPE,
    
    -- Transaction Counts
    COUNT(DISTINCT TXN_ID) AS TOTAL_TXNS,
    
    -- Revenue Components
    SUM(REVENUE) AS TOTAL_REVENUE,
    SUM(FEE) AS TOTAL_FEE,
    SUM(FX_MARGIN) AS TOTAL_FX_MARGIN,
    
    -- Averages
    AVG(REVENUE) AS AVG_REVENUE,
    AVG(FEE) AS AVG_FEE,
    AVG(FX_MARGIN) AS AVG_FX_MARGIN,
    
    -- Revenue Composition (what % comes from Fee vs FX)
    SUM(FEE) / NULLIF(SUM(REVENUE), 0) * 100 AS FEE_PCT_OF_REVENUE,
    SUM(FX_MARGIN) / NULLIF(SUM(REVENUE), 0) * 100 AS FX_PCT_OF_REVENUE,
    
    -- As % of Principal
    AVG(FEE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_FEE_AS_PCT_PRINCIPAL,
    AVG(FX_MARGIN / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_FX_AS_PCT_PRINCIPAL,
    AVG(REVENUE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_REVENUE_AS_PCT_PRINCIPAL

FROM WUDNA.SUMMARY_GEN.WUDNA_TXN_MASTER_ANALYTICS_VW
WHERE SNDCOUNTRY_CODE = 'US'
    AND DATE(rcvpaying_datetime) >= '2025-02-01'
    AND DATE(rcvpaying_datetime) < '2026-02-01'
    AND PAYOUT_TYPE IN ('ACCOUNT', 'CASH')
    AND SNDCUSTOMER_KEY IS NOT NULL
GROUP BY PAYOUT_TYPE;

-- Verification Query
SELECT * FROM CAM_1746_REVENUE_COMPOSITION
ORDER BY PAYOUT_TYPE;


