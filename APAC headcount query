-- ============================================================================
-- MERGED MULTI-DIMENSIONAL CASH VS APN ANALYSIS
-- ============================================================================
-- Purpose: Single comprehensive query with all dimensions
-- Dimensions: Payout Type + Channel + Principal Bucket + IMT/DMT
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_CASH_VS_APN_ALL_DIMENSIONS AS
SELECT
    PAYOUT_TYPE,
    
    -- Channel Dimension
    CASE
        WHEN PRICING_CHANNEL IN ('WEB', 'APP') THEN 'DIGITAL'
        WHEN PRICING_CHANNEL IN ('POS', 'TMT', 'AIR') THEN 'RETAIL'
        ELSE 'OTHER'
    END AS CHANNEL_GROUP,
    
    -- Principal Bucket Dimension
    CASE
        WHEN SNDPRINCIPAL_USD < 100 THEN 'A.<$100'
        WHEN SNDPRINCIPAL_USD >= 100 AND SNDPRINCIPAL_USD < 500 THEN 'B.$100-$500'
        WHEN SNDPRINCIPAL_USD >= 500 AND SNDPRINCIPAL_USD < 1000 THEN 'C.$500-$1,000'
        WHEN SNDPRINCIPAL_USD >= 1000 AND SNDPRINCIPAL_USD < 2000 THEN 'D.$1,000-$2,000'
        WHEN SNDPRINCIPAL_USD >= 2000 AND SNDPRINCIPAL_USD < 5000 THEN 'E.$2,000-$5,000'
        WHEN SNDPRINCIPAL_USD >= 5000 THEN 'F.$5,000+'
        ELSE 'Unknown'
    END AS PPT_BUCKET,
    
    -- Corridor Type Dimension (IMT/DMT)
    CASE 
        WHEN SNDCOUNTRY_CODE = RCVCOUNTRY_CODE THEN 'DOMESTIC' 
        ELSE 'CROSS BORDER' 
    END AS DIRECTION,
    
    -- Counts
    COUNT(DISTINCT SNDCUSTOMER_KEY) AS DISTINCT_CUSTOMERS,
    COUNT(DISTINCT TXN_ID) AS TOTAL_TXNS,
    
    -- Principal Metrics
    SUM(SNDPRINCIPAL_USD) AS TOTAL_PRINCIPAL,
    AVG(SNDPRINCIPAL_USD) AS AVG_PRINCIPAL,
    MEDIAN(SNDPRINCIPAL_USD) AS MEDIAN_PRINCIPAL,
    
    -- Revenue Metrics
    SUM(REVENUE) AS TOTAL_REVENUE,
    AVG(REVENUE) AS AVG_REVENUE,
    MEDIAN(REVENUE) AS MEDIAN_REVENUE,
    
    -- Fee Metrics
    SUM(FEE) AS TOTAL_FEE,
    AVG(FEE) AS AVG_FEE,
    MEDIAN(FEE) AS MEDIAN_FEE,
    
    -- FX Margin Metrics
    SUM(FX_MARGIN) AS TOTAL_FX_MARGIN,
    AVG(FX_MARGIN) AS AVG_FX_MARGIN,
    MEDIAN(FX_MARGIN) AS MEDIAN_FX_MARGIN,
    
    -- Calculated Percentages
    AVG(REVENUE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_REVENUE_PCT_OF_PRINCIPAL,
    AVG(FEE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_FEE_PCT_OF_PRINCIPAL,
    AVG(FX_MARGIN / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_FX_PCT_OF_PRINCIPAL,
    
    -- Revenue Composition
    SUM(FEE) / NULLIF(SUM(REVENUE), 0) * 100 AS FEE_PCT_OF_REVENUE,
    SUM(FX_MARGIN) / NULLIF(SUM(REVENUE), 0) * 100 AS FX_PCT_OF_REVENUE

FROM WUDNA.SUMMARY_GEN.WUDNA_TXN_MASTER_ANALYTICS_VW
WHERE SNDCOUNTRY_CODE = 'US'
    AND DATE(rcvpaying_datetime) >= '2025-02-01'
    AND DATE(rcvpaying_datetime) < '2026-02-01'
    AND PAYOUT_TYPE IN ('ACCOUNT', 'CASH')
    AND SNDCUSTOMER_KEY IS NOT NULL
GROUP BY PAYOUT_TYPE, CHANNEL_GROUP, PPT_BUCKET, DIRECTION
ORDER BY PAYOUT_TYPE, CHANNEL_GROUP, PPT_BUCKET, DIRECTION;

