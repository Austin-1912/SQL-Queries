### **Modified Aggregation Table:**

```sql
CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_EMAIL_SMS_WH_AGG AS
SELECT
    CAMPAIGN_NAME,
    DATE(CAMPAIGN_DATE) AS CAMPAIGN_DATE,
    CHANNEL_TYPE,
    CASE WHEN UPPER(CAMPAIGN_NAME) ILIKE ANY ('%LIFECYCLE%', '%TRIGGER%') THEN 'LIFECYCLE'
    ELSE 'ADHOC' END AS JOURNEY,
    
    -- Original counts
    SUM(IS_TEST_IN_CAMPAIGN)       AS TOTAL_TEST_CUSTOMERS,
    SUM(IS_CONTROL_IN_CAMPAIGN)    AS TOTAL_CONTROL_CUSTOMERS,
    SUM(IS_GH_IN_CAMPAIGN)         AS TOTAL_GLOBAL_HOLDOUT_CUSTOMERS,
    
    -- Customer Master GH count
    SUM(CASE WHEN IS_GH_IN_CUSTOMER_MASTER = 'Y' THEN 1 ELSE 0 END) AS TOTAL_GH_PER_CUSTOMER_MASTER,
    
    -- Contamination counts
    SUM(CONTAMINATION_TEST_BUT_GH_IN_CM)        AS CONTAMINATION_TEST_BUT_GH,
    SUM(CONTAMINATION_CONTROL_BUT_GH_IN_CM)     AS CONTAMINATION_CONTROL_BUT_GH,
    SUM(CONTAMINATION_GH_BUT_NOT_IN_CM)         AS CONTAMINATION_GH_BUT_NOT_IN_CM
    
FROM AM_ONE_STOP_CAM_TRACKER_EMAIL_SMS_WH_CUST_LEVEL
GROUP BY ALL;
```

