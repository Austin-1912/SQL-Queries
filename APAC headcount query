-- ============================================================================
-- CASH VS APN PRICING ANALYSIS - ENTIRE US POPULATION
-- ============================================================================
-- Purpose: Understand why APN has higher PPT but lower RPT compared to CASH
-- Hypothesis: ACCOUNT payout has more competitive pricing (lower fees/FX margins)
-- Period: Feb 2025 - Jan 2026
-- ============================================================================

-- ============================================================================
-- STEP 1: OVERALL CASH VS APN COMPARISON
-- ============================================================================
-- Purpose: High-level comparison of transaction behavior and pricing
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_CASH_VS_APN_OVERALL AS
SELECT
    PAYOUT_TYPE,
    COUNT(DISTINCT SNDCUSTOMER_KEY) AS DISTINCT_CUSTOMERS,
    COUNT(DISTINCT TXN_ID) AS TOTAL_TXNS,
    
    -- Principal Metrics
    SUM(SNDPRINCIPAL_USD) AS TOTAL_PRINCIPAL,
    AVG(SNDPRINCIPAL_USD) AS AVG_PRINCIPAL_PPT,
    MEDIAN(SNDPRINCIPAL_USD) AS MEDIAN_PRINCIPAL_PPT,
    
    -- Revenue Metrics
    SUM(REVENUE) AS TOTAL_REVENUE,
    AVG(REVENUE) AS AVG_REVENUE_RPT,
    MEDIAN(REVENUE) AS MEDIAN_REVENUE_RPT,
    
    -- Fee Metrics
    SUM(FEE) AS TOTAL_FEE,
    AVG(FEE) AS AVG_FEE,
    MEDIAN(FEE) AS MEDIAN_FEE,
    
    -- FX Margin Metrics (if applicable)
    SUM(FX_MARGIN) AS TOTAL_FX_MARGIN,
    AVG(FX_MARGIN) AS AVG_FX_MARGIN,
    MEDIAN(FX_MARGIN) AS MEDIAN_FX_MARGIN,
    
    -- Calculated Metrics
    AVG(REVENUE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_REVENUE_AS_PCT_OF_PRINCIPAL,
    AVG(FEE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_FEE_AS_PCT_OF_PRINCIPAL,
    AVG(FX_MARGIN / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_FX_AS_PCT_OF_PRINCIPAL

FROM WUDNA.SUMMARY_GEN.WUDNA_TXN_MASTER_ANALYTICS_VW
WHERE SNDCOUNTRY_CODE = 'US'
    AND DATE(rcvpaying_datetime) >= '2025-02-01'
    AND DATE(rcvpaying_datetime) < '2026-02-01'
    AND PAYOUT_TYPE IN ('ACCOUNT', 'CASH')
    AND SNDCUSTOMER_KEY IS NOT NULL
GROUP BY PAYOUT_TYPE;

-- Verification Query
SELECT * FROM CAM_1746_CASH_VS_APN_OVERALL
ORDER BY PAYOUT_TYPE;


-- ============================================================================
-- STEP 2: CASH VS APN BY PRINCIPAL BUCKET
-- ============================================================================
-- Purpose: Compare pricing across different principal (PPT) buckets
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_CASH_VS_APN_BY_PPT_BUCKET AS
SELECT
    PAYOUT_TYPE,
    CASE
        WHEN SNDPRINCIPAL_USD < 100 THEN 'A.<$100'
        WHEN SNDPRINCIPAL_USD >= 100 AND SNDPRINCIPAL_USD < 500 THEN 'B.$100-$500'
        WHEN SNDPRINCIPAL_USD >= 500 AND SNDPRINCIPAL_USD < 1000 THEN 'C.$500-$1,000'
        WHEN SNDPRINCIPAL_USD >= 1000 AND SNDPRINCIPAL_USD < 2000 THEN 'D.$1,000-$2,000'
        WHEN SNDPRINCIPAL_USD >= 2000 AND SNDPRINCIPAL_USD < 5000 THEN 'E.$2,000-$5,000'
        WHEN SNDPRINCIPAL_USD >= 5000 THEN 'F.$5,000+'
        ELSE 'Unknown'
    END AS PPT_BUCKET,
    
    COUNT(DISTINCT SNDCUSTOMER_KEY) AS DISTINCT_CUSTOMERS,
    COUNT(DISTINCT TXN_ID) AS TOTAL_TXNS,
    
    -- Principal
    SUM(SNDPRINCIPAL_USD) AS TOTAL_PRINCIPAL,
    AVG(SNDPRINCIPAL_USD) AS AVG_PRINCIPAL,
    
    -- Revenue
    SUM(REVENUE) AS TOTAL_REVENUE,
    AVG(REVENUE) AS AVG_REVENUE,
    
    -- Fee
    SUM(FEE) AS TOTAL_FEE,
    AVG(FEE) AS AVG_FEE,
    
    -- FX Margin
    SUM(FX_MARGIN) AS TOTAL_FX_MARGIN,
    AVG(FX_MARGIN) AS AVG_FX_MARGIN,
    
    -- Percentages
    AVG(REVENUE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_REVENUE_PCT,
    AVG(FEE / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_FEE_PCT,
    AVG(FX_MARGIN / NULLIF(SNDPRINCIPAL_USD, 0) * 100) AS AVG_FX_PCT

FROM WUDNA.SUMMARY_GEN.WUDNA_TXN_MASTER_ANALYTICS_VW
WHERE SNDCOUNTRY_CODE = 'US'
    AND DATE(rcvpaying_datetime) >= '2025-02-01'
    AND DATE(rcvpaying_datetime) < '2026-02-01'
    AND PAYOUT_TYPE IN ('ACCOUNT', 'CASH')
    AND SNDCUSTOMER_KEY IS NOT NULL
GROUP BY PAYOUT_TYPE, PPT_BUCKET
ORDER BY PPT_BUCKET, PAYOUT_TYPE;

-- Verification Query
SELECT * FROM CAM_1746_CASH_VS_APN_BY_PPT_BUCKET
ORDER BY PPT_BUCKET, PAYOUT_TYPE;


