## **Step 5: Update Final Rollup to Include Contamination Metrics**

```sql
CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_FINAL_TABLE AS
SELECT
    CAMPAIGN_NAME,
    DATE(CAMPAIGN_DATE) AS CAMPAIGN_DATE,
    CHANNEL_TYPE,
    JOURNEY,
    
    -- Original metrics
    SUM(TOTAL_TEST_CUSTOMERS) AS TOTAL_TEST_CUSTOMERS,
    SUM(TOTAL_CONTROL_CUSTOMERS) AS TOTAL_CONTROL_CUSTOMERS,
    SUM(TOTAL_GLOBAL_HOLDOUT_CUSTOMERS) AS TOTAL_GLOBAL_HOLDOUT_CUSTOMERS,
    
    -- Customer Master comparison
    SUM(TOTAL_GH_PER_CUSTOMER_MASTER) AS TOTAL_GH_PER_CUSTOMER_MASTER,
    
    -- Contamination metrics
    SUM(CONTAMINATION_TEST_BUT_GH) AS CONTAMINATION_TEST_BUT_GH,
    SUM(CONTAMINATION_CONTROL_BUT_GH) AS CONTAMINATION_CONTROL_BUT_GH,
    SUM(CONTAMINATION_GH_BUT_NOT_IN_CM) AS CONTAMINATION_GH_BUT_NOT_IN_CM,
    
    -- Calculated: Total contamination
    SUM(CONTAMINATION_TEST_BUT_GH) + 
    SUM(CONTAMINATION_CONTROL_BUT_GH) + 
    SUM(CONTAMINATION_GH_BUT_NOT_IN_CM) AS TOTAL_CONTAMINATION
    
FROM (
    SELECT * FROM AM_ONE_STOP_CAM_TRACKER_EMAIL_SMS_WH_AGG
    UNION ALL
    SELECT * FROM AM_ONE_STOP_CAM_TRACKER_APP_UNION
)
GROUP BY CAMPAIGN_NAME, CAMPAIGN_DATE, CHANNEL_TYPE, JOURNEY
ORDER BY CAMPAIGN_DATE, CAMPAIGN_NAME;
```

