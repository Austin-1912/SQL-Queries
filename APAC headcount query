Then, in a separate helper table, calculate the retail pool denominator — pull a second query or add a tab:
-- Optional add-on: retail pool denominator for rate calculation
SELECT
    TO_CHAR(DATE_TRUNC('MONTH', txn_date), 'YYYY-MM')  AS pool_month,
    sndcountry_code                                     AS send_market,
    corridor,
    COUNT(DISTINCT sndcustomer_key)                     AS retail_pool_size
FROM (
    SELECT b.sndcustomer_key, b.txn_date, b.sndcountry_code, b.corridor,
           mn.analysis_month
    FROM CAR_861_BASE b
    CROSS JOIN (
        SELECT COLUMN1::DATE AS analysis_month
        FROM VALUES ('2025-01-01'),('2025-02-01'),('2025-03-01'),
                    ('2025-04-01'),('2025-05-01'),('2025-06-01'),
                    ('2025-07-01'),('2025-08-01'),('2025-09-01'),
                    ('2025-10-01'),('2025-11-01'),('2025-12-01')
    ) mn
    WHERE b.channel_type = 'RETAIL'
      AND b.txn_date >= DATEADD('MONTH',-12, mn.analysis_month)
      AND b.txn_date <  mn.analysis_month
)
GROUP BY 1,2,3;
