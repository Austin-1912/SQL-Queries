## **Step 6: Create Contamination Report Table**

```sql
CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_CONTAMINATION_REPORT AS
SELECT
    CAMPAIGN_NAME,
    CAMPAIGN_DATE,
    CHANNEL_TYPE,
    JOURNEY,
    
    -- Total customers
    TOTAL_TEST_CUSTOMERS + TOTAL_CONTROL_CUSTOMERS + TOTAL_GLOBAL_HOLDOUT_CUSTOMERS AS TOTAL_CUSTOMERS,
    
    -- Original distribution
    TOTAL_TEST_CUSTOMERS,
    TOTAL_CONTROL_CUSTOMERS,
    TOTAL_GLOBAL_HOLDOUT_CUSTOMERS,
    TOTAL_GH_PER_CUSTOMER_MASTER,
    
    -- Contamination counts
    CONTAMINATION_TEST_BUT_GH,
    CONTAMINATION_CONTROL_BUT_GH,
    CONTAMINATION_GH_BUT_NOT_IN_CM,
    TOTAL_CONTAMINATION,
    
    -- Contamination rates
    ROUND(CONTAMINATION_TEST_BUT_GH * 100.0 / NULLIF(TOTAL_TEST_CUSTOMERS, 0), 2) AS PCT_TEST_CONTAMINATED,
    ROUND(CONTAMINATION_CONTROL_BUT_GH * 100.0 / NULLIF(TOTAL_CONTROL_CUSTOMERS, 0), 2) AS PCT_CONTROL_CONTAMINATED,
    ROUND(CONTAMINATION_GH_BUT_NOT_IN_CM * 100.0 / NULLIF(TOTAL_GLOBAL_HOLDOUT_CUSTOMERS, 0), 2) AS PCT_GH_CONTAMINATED,
    
    -- Overall contamination rate
    ROUND(TOTAL_CONTAMINATION * 100.0 / NULLIF(TOTAL_TEST_CUSTOMERS + TOTAL_CONTROL_CUSTOMERS + TOTAL_GLOBAL_HOLDOUT_CUSTOMERS, 0), 2) AS OVERALL_CONTAMINATION_PCT,
    
    -- GH alignment check
    CASE 
        WHEN TOTAL_GLOBAL_HOLDOUT_CUSTOMERS = TOTAL_GH_PER_CUSTOMER_MASTER THEN 'ALIGNED'
        WHEN ABS(TOTAL_GLOBAL_HOLDOUT_CUSTOMERS - TOTAL_GH_PER_CUSTOMER_MASTER) / NULLIF(TOTAL_GH_PER_CUSTOMER_MASTER, 1) < 0.05 THEN 'MINOR_VARIANCE'
        ELSE 'MISALIGNED'
    END AS GH_ALIGNMENT_STATUS

FROM AM_ONE_STOP_CAM_TRACKER_FINAL_TABLE
WHERE TOTAL_CONTAMINATION > 0 OR TOTAL_GLOBAL_HOLDOUT_CUSTOMERS != TOTAL_GH_PER_CUSTOMER_MASTER
ORDER BY TOTAL_CONTAMINATION DESC, CAMPAIGN_DATE DESC;
```

