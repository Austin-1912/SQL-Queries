    CANVAS_STEP_NAME_new,
      -- Flags
    0 AS IS_TEST_IN_CAMPAIGN,
    0 AS IS_CONTROL_IN_CAMPAIGN,
    1 AS IS_GH_IN_CAMPAIGN,
    
    -- Customer Master GH flag
  CM.GLOBAL_HOLDOUT AS IS_GH_IN_CUSTOMER_MASTER,
    
    -- Contamination
    0 AS CONTAMINATION_TEST_BUT_GH_IN_CM,
    0 AS CONTAMINATION_CONTROL_BUT_GH_IN_CM,
    CASE WHEN CM.GLOBAL_HOLDOUT = 'N' THEN 1 ELSE 0 END AS CONTAMINATION_GH_BUT_NOT_IN_CM

FROM SUMMARY_GEN.BRAZE_SUMMARY_VW A
LEFT JOIN "WUDNA"."SUMMARY_GEN"."WUDNA_ACCOUNT_MASTER_VW" B 
    ON A.CUSTOMER_KEY = B.CUSTOMER_UMN
    
-- JOIN Customer Master
LEFT JOIN "WUDNA"."SUMMARY_GEN"."WUDNA_CUSTOMER_MASTER_VW" CM
    ON CASE WHEN LENGTH(A.CUSTOMER_KEY) = 19 THEN A.CUSTOMER_KEY ELSE B.CUSTOMER_KEY END = CM.CUSTOMER_KEY
WHERE
    A.CUSTOMER_KEY IS NOT NULL
    AND B.CUSTOMER_KEY IS NOT NULL
    AND TO_DATE(CAMPAIGN_DATE) not like '2099-01-01'
    AND TYPE = 'CANVAS'
    AND Activity_code_new LIKE 'G%'                      
    AND TO_DATE(CAMPAIGN_DATE) >= '2026-01-01'          
    AND TO_DATE(CAMPAIGN_DATE) <  DATE_TRUNC('MONTH', CURRENT_DATE())
    AND REGEXP_SUBSTR(B.customer_key, '[a-zA-Z]') IS NULL
    AND LENGTH(A.customer_key) IN (9,19)
    AND NOT UPPER(CAMPAIGN_CANVAS_NAME) ILIKE ANY ('%FULFILLMENT%','%STAGE_%','STGE_%','TEST%','%WUPLUS%','%LIFECYCLE_ONBOARDING_CTADIGITAL_WP%','%UNKNOWN%','%APOLOGY%','%SURVEY%','%RCVX%','UAT%','%SERVICE%')
ORDER BY customer_key, CAMPAIGN_DATE;


CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_CANVAS_APP_GH_AGG AS
SELECT
    CAMPAIGN_NAME,
     DATE(CAMPAIGN_DATE) AS CAMPAIGN_DATE,
     CHANNEL_TYPE,
     CASE WHEN UPPER(CAMPAIGN_NAME) ILIKE ANY ('%LIFECYCLE%', '%TRIGGER%') THEN 'LIFECYCLE'
    ELSE 'ADHOC' END AS JOURNEY,
      0 AS TOTAL_TEST_CUSTOMERS,
    0 AS TOTAL_CONTROL_CUSTOMERS,
    SUM(IS_GH_IN_CAMPAIGN) AS TOTAL_GLOBAL_HOLDOUT_CUSTOMERS,  
      -- Customer Master comparison
    SUM(CASE WHEN IS_GH_IN_CUSTOMER_MASTER = 'Y' THEN 1 ELSE 0 END) AS TOTAL_GH_PER_CUSTOMER_MASTER,
    
    -- Contamination
    0 AS CONTAMINATION_TEST_BUT_GH,
    0 AS CONTAMINATION_CONTROL_BUT_GH,
    SUM(CONTAMINATION_GH_BUT_NOT_IN_CM)  AS CONTAMINATION_GH_BUT_NOT_IN_CM
FROM AM_ONE_STOP_CAM_TRACKER_CANVAS_APP_GH_CUST_LEVEL
GROUP BY ALL;


CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_CANVAS_UNION AS
SELECT * FROM AM_ONE_STOP_CAM_TRACKER_CANVAS_APP_TEST_AGG
UNION ALL
SELECT * FROM AM_ONE_STOP_CAM_TRACKER_CANVAS_APP_CONTROL_AGG
UNION ALL
SELECT * FROM AM_ONE_STOP_CAM_TRACKER_CANVAS_APP_GH_AGG;


