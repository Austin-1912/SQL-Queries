-- ============================================================
-- STREAM 1: EMAIL / SMS / WEBHOOK (SOLICITATION HISTORY)
-- ============================================================

CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_EMAIL_SMS_WH_CUST_LEVEL AS
SELECT
    sh.customer_key,
    sh.RELEASE_2_VENDOR_DATE AS CAMPAIGN_DATE,
    sh.CAMPAIGN_DESC AS CAMPAIGN_NAME,
    CASE 
        WHEN SUBSTR(sh.activity_code,3,1) = 'E' THEN 'EMAIL'
        WHEN SUBSTR(sh.activity_code,3,1) = 'S' THEN 'SMS' 
        WHEN SUBSTR(sh.activity_code,3,1) = 'W' THEN 'WHATSAPP' 
    END AS CHANNEL_TYPE,
    
    -- Campaign assignment flags
    CASE WHEN SUBSTR(sh.activity_code,1,1) = 'S' THEN 1 ELSE 0 END AS IS_TEST_IN_CAMPAIGN,
    CASE WHEN SUBSTR(sh.activity_code,1,1) = 'C' THEN 1 ELSE 0 END AS IS_CONTROL_IN_CAMPAIGN,
    CASE WHEN SUBSTR(sh.activity_code,1,1) = 'G' THEN 1 ELSE 0 END AS IS_GH_IN_CAMPAIGN,
    
    -- Customer Master GH flag
    cm.GLOBAL_HOLDOUT AS IS_GH_IN_CUSTOMER_MASTER,
    
    -- Contamination flags
    CASE 
        WHEN SUBSTR(sh.activity_code,1,1) = 'S' AND COALESCE(cm.GLOBAL_HOLDOUT, 'N') = 'Y' 
        THEN 1 ELSE 0 
    END AS CONTAMINATION_TEST_BUT_GH_IN_CM,
    
    CASE 
        WHEN SUBSTR(sh.activity_code,1,1) = 'C' AND COALESCE(cm.GLOBAL_HOLDOUT, 'N') = 'Y' 
        THEN 1 ELSE 0 
    END AS CONTAMINATION_CONTROL_BUT_GH_IN_CM,
    
    CASE 
        WHEN SUBSTR(sh.activity_code,1,1) = 'G' AND COALESCE(cm.GLOBAL_HOLDOUT, 'N') = 'N' 
        THEN 1 ELSE 0 
    END AS CONTAMINATION_GH_BUT_NOT_IN_CM

FROM "WUDNA"."SUMMARY_GEN"."WUDNA_SOLICITATION_HISTORY_VW" sh

-- JOIN to Customer Master
LEFT JOIN "WUDNA"."SUMMARY_GEN"."WUDNA_CUSTOMER_MASTER_VW" cm
    ON sh.customer_key = cm.customer_key
WHERE
 NOT UPPER(CAMPAIGN_DESC) ILIKE ANY ('%FULFILLMENT%','%STAGE_%','STGE_%','TEST%','%WUPLUS%','%LIFECYCLE_ONBOARDING_CTADIGITAL_WP%','%UNKNOWN%','%APOLOGY%','%SURVEY%','%RCVX%','UAT%','%SERVICE%')
  AND DATE(RELEASE_2_VENDOR_DATE) >= '2026-01-01'
  AND DATE(RELEASE_2_VENDOR_DATE) <  DATE_TRUNC('MONTH', CURRENT_DATE())
GROUP BY ALL;


CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_EMAIL_SMS_WH_AGG AS
SELECT
    CAMPAIGN_NAME,
    DATE(CAMPAIGN_DATE) AS CAMPAIGN_DATE,
    CHANNEL_TYPE,
    CASE WHEN UPPER(CAMPAIGN_NAME) ILIKE ANY ('%LIFECYCLE%', '%TRIGGER%') THEN 'LIFECYCLE'
    ELSE 'ADHOC' END AS JOURNEY,
    -- Original counts
    SUM(IS_TEST_IN_CAMPAIGN)       AS TOTAL_TEST_CUSTOMERS,
    SUM(IS_CONTROL_IN_CAMPAIGN)    AS TOTAL_CONTROL_CUSTOMERS,
    SUM(IS_GH_IN_CAMPAIGN)         AS TOTAL_GLOBAL_HOLDOUT_CUSTOMERS,
    
    -- Customer Master GH count
    SUM(CASE WHEN IS_GH_IN_CUSTOMER_MASTER = 'Y' THEN 1 ELSE 0 END) AS TOTAL_GH_PER_CUSTOMER_MASTER,
    
    -- Contamination counts
    SUM(CONTAMINATION_TEST_BUT_GH_IN_CM)        AS CONTAMINATION_TEST_BUT_GH,
    SUM(CONTAMINATION_CONTROL_BUT_GH_IN_CM)     AS CONTAMINATION_CONTROL_BUT_GH,
    SUM(CONTAMINATION_GH_BUT_NOT_IN_CM)         AS CONTAMINATION_GH_BUT_NOT_IN_CM

FROM AM_ONE_STOP_CAM_TRACKER_EMAIL_SMS_WH_CUST_LEVEL
GROUP BY ALL;

