;

CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_CANVAS_APP_TEST_CUST_LEVEL AS 
select 
        UPPER(A.CAMPAIGN_CANVAS_NAME) as CAMPAIGN_NAME, 
        case when length(A.CUSTOMER_KEY) =19 then A.CUSTOMER_KEY
             else B.CUSTOMER_KEY
        end as CUSTOMER_KEY,

        case when substr(activity_code_new,3,1)='P' AND push_sent_date IS NOT NULL then push_sent_date
            when substr(activity_code_new,3,1)='I' AND inappmsg_viewed_date IS NOT NULL then inappmsg_viewed_date
            when substr(activity_code_new,  3,1)='C' AND cc_sent_date IS NOT NULL then cc_sent_date
            when substr(activity_code_new,3,1)='W' AND Webhook_sent_date IS NOT NULL then webhook_sent_date
        ELSE TO_DATE('2099-01-01') -- SETTING AN ABSURD DATE SO THAT NO TXN DATA GETS JOINED
        END AS CAMPAIGN_DATE,
        'TEST_CUST' as TEST_CUSTOMERS
        
from SUMMARY_GEN.BRAZE_SUMMARY_VW A
Left Join "WUDNA"."SUMMARY_GEN".WUDNA_ACCOUNT_MASTER_VW B on A.CUSTOMER_KEY = B.CUSTOMER_UMN
 
where
    A.CUSTOMER_KEY is not null 
	and B.CUSTOMER_KEY is not null 
    and to_date(CAMPAIGN_DATE) not like '2099-01-01' 
    and TYPE='CANVAS' 
    and Activity_code_new like 'S%'
    AND to_date(CAMPAIGN_DATE) >= '2025-02-01'
    and to_date(CAMPAIGN_DATE) < DATE_TRUNC('MONTH', CURRENT_DATE()) -- Change the date every month refresh--changed it to May 2025--PK
    and regexp_substr(B.customer_key, '[a-zA-Z]') is null
    and canvas_step_name_new not in ('X')
    and length(A.customer_key) in (9,19)
        AND not upper(CAMPAIGN_CANVAS_NAME) ILIKE any ('TEST%','%UNKNOWN%','%RCVX%')
    AND DATE(CAMPAIGN_DATE) >= '2025-01-01'
order by 
    customer_key,
    COMMUNICATION_DATE;

