CREATE OR REPLACE TABLE CAR_921_US_IPF_LIST_TILL_DATE AS
select 
        distinct c.customer_key, 
        c.customer_umn,
        c.country_code, 
        'Y' AS email_marketable_flag,
        c.global_holdout,
        c.loyalty_member_flag,
        c.interpurchase_freq_beats, 
        c.prfrd_language_code
from WUDNA.SUMMARY_GEN.WUDNA_CUSTOMER_MASTER_VW c
INNER JOIN  WUDNA.SUMMARY_GEN.WUDNA_TXN_MASTER_ANALYTICS_VW t ON c.customer_key = t.sndcustomer_key
INNER JOIN WUDNA.SUMMARY_GEN.WUDNA_BIRD_ALL_CONTACTS_VW b ON c.customer_key = b.customer_key
where country_code = 'US'
and c.global_holdout = 'N'
AND DATE(rcvpaying_datetime) >= '2025-03-19'
AND DATE(rcvpaying_datetime) < '2026-03-18'
AND c.marketing_flag             = 'Y'
AND c.email_address_on_file_flag = 'Y'
AND c.opt_email  = 'I'
AND c.prfrd_language_code IN ('EN', 'ES')
group by all;
