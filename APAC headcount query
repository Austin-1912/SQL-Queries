SUM(a.PUSH_INFLU_OPEN_COUNT) AS PUSH_INFLU_OPEN_COUNT,
SUM(a.PUSH_BOUNCE_COUNT) AS PUSH_BOUNCE_COUNT,
SUM(a.INAPPMSG_VIEWED_COUNT) AS INAPPMSG_VIEWED_COUNT,
SUM(a.INAPPMSG_CLICKED_COUNT) AS INAPPMSG_CLICKED_COUNT,
SUM(a.CC_CLICKED_COUNT) AS CC_CLICKED_COUNT,
SUM(a.CC_VIEWED_COUNT) AS CC_VIEWED_COUNT,
SUM(a.CC_DISMISSED_COUNT) AS CC_DISMISSED_COUNT,
SUM(a.CC_ABORTED_COUNT) AS CC_ABORTED_COUNT,
SUM(a.PUSH_SENT_COUNT) AS PUSH_SENT_COUNT,
SUM(a.CC_SENT_COUNT) AS CC_SENT_COUNT

From SJ_bi_campaign_wise_email_communications_2_v2_mywu_UPDATE a
LEFT JOIN AM_BI_CAMPAIGN_WISE_CORRIDOR_AGG_TEST b
ON a.campaign_name = b.campaign_name
AND a.EVENT_CAPTURED_dt = b.EVENT_CAPTURED_DT
where a.event_captured_dt >= '2026-01-01'
group by all;
