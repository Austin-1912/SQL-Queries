CREATE OR REPLACE TABLE CAR_946_SG_TO_IN AS
SELECT
    COUNT(t.txn_id) AS Total_Txns,
    COUNT(CASE WHEN t.PRICING_CHANNEL = 'APP' THEN t.txn_id END) AS APP_TXNS,
    t.SNDCUSTOMER_KEY,  
    t.sndcountry_code,
    CASE WHEN t.pricing_channel IN ('APP', 'WEB') THEN 'DIGITAL' 
    WHEN t.pricing_channel IN ('POS', 'TMT') THEN 'RETAIL' 
    END AS channel,
    t.RCVCOUNTRY_CODE
FROM SUMMARY_GEN.WUDNA_TXN_MASTER_ANALYTICS_VW t
WHERE UPPER(t.SNDCOUNTRY_CODE) = 'SG'
  AND UPPER(t.RCVCOUNTRY_CODE) = 'IN'
  AND DATE(t.RCVPAYING_DATETIME) >= '2025-03-24' AND 
  DATE(t.RCVPAYING_DATETIME) <= '2026-03-23'
GROUP BY ALL;

