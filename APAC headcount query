SELECT
    campaign_name,
    txn_corridor,
    SUM(txns) as corridor_txns,
    ROW_NUMBER() OVER (
        PARTITION BY campaign_name
        ORDER BY SUM(txns) DESC NULLS LAST, txn_corridor ASC
    ) AS corr_rank
FROM AM_BI_CAMPAIGN_WISE_CORRIDOR_MYWU_UPDATE_CUSTOMER_LEVEL
WHERE campaign_name = 'YOUR_CAMPAIGN_NAME'
  AND event_captured_dt >= '2026-01-01'
  AND len(CUSTOMER_KEY) IN (9,15,19)
GROUP BY campaign_name, txn_corridor, ACTIVITY_STATUS
