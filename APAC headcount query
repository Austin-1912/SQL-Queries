-- ============================================================================
-- COMPREHENSIVE VERIFICATION SUMMARY
-- ============================================================================
-- Purpose: Single view to check if all levels match
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_VERIFICATION_SUMMARY AS

-- Overall Level
SELECT 
    'OVERALL' AS aggregation_level,
    PAYOUT_TYPE AS dimension_value,
    SUM(TOTAL_TXNS) AS txn_count,
    SUM(TOTAL_PRINCIPAL) / SUM(TOTAL_TXNS) AS avg_principal_from_merged,
    SUM(TOTAL_REVENUE) / SUM(TOTAL_TXNS) AS avg_revenue_from_merged,
    SUM(TOTAL_FEE) / SUM(TOTAL_TXNS) AS avg_fee_from_merged
FROM CAM_1746_CASH_VS_APN_ALL_DIMENSIONS
GROUP BY PAYOUT_TYPE

UNION ALL

-- Channel Level
SELECT 
    'CHANNEL' AS aggregation_level,
    CONCAT(PAYOUT_TYPE, ' - ', CHANNEL_GROUP) AS dimension_value,
    SUM(TOTAL_TXNS) AS txn_count,
    SUM(TOTAL_PRINCIPAL) / SUM(TOTAL_TXNS) AS avg_principal_from_merged,
    SUM(TOTAL_REVENUE) / SUM(TOTAL_TXNS) AS avg_revenue_from_merged,
    SUM(TOTAL_FEE) / SUM(TOTAL_TXNS) AS avg_fee_from_merged
FROM CAM_1746_CASH_VS_APN_ALL_DIMENSIONS
GROUP BY PAYOUT_TYPE, CHANNEL_GROUP

UNION ALL

-- PPT Bucket Level
SELECT 
    'PPT_BUCKET' AS aggregation_level,
    CONCAT(PAYOUT_TYPE, ' - ', PPT_BUCKET) AS dimension_value,
    SUM(TOTAL_TXNS) AS txn_count,
    SUM(TOTAL_PRINCIPAL) / SUM(TOTAL_TXNS) AS avg_principal_from_merged,
    SUM(TOTAL_REVENUE) / SUM(TOTAL_TXNS) AS avg_revenue_from_merged,
    SUM(TOTAL_FEE) / SUM(TOTAL_TXNS) AS avg_fee_from_merged
FROM CAM_1746_CASH_VS_APN_ALL_DIMENSIONS
GROUP BY PAYOUT_TYPE, PPT_BUCKET

UNION ALL

-- Direction Level
SELECT 
    'DIRECTION' AS aggregation_level,
    CONCAT(PAYOUT_TYPE, ' - ', DIRECTION) AS dimension_value,
    SUM(TOTAL_TXNS) AS txn_count,
    SUM(TOTAL_PRINCIPAL) / SUM(TOTAL_TXNS) AS avg_principal_from_merged,
    SUM(TOTAL_REVENUE) / SUM(TOTAL_TXNS) AS avg_revenue_from_merged,
    SUM(TOTAL_FEE) / SUM(TOTAL_TXNS) AS avg_fee_from_merged
FROM CAM_1746_CASH_VS_APN_ALL_DIMENSIONS
GROUP BY PAYOUT_TYPE, DIRECTION

ORDER BY aggregation_level, dimension_value;

