CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_EMAIL_SMS_WH_CUST_LEVEL AS
SELECT 
    customer_key,
    RELEASE_2_VENDOR_DATE AS CAMPAIGN_DATE,
    CAMPAIGN_DESC AS CAMPAIGN_NAME,
    COUNT(CASE WHEN SUBSTR(activity_code,1,1) = 'S' THEN 1 END) AS TEST_CUSTOMERS,
    COUNT(CASE WHEN SUBSTR(activity_code,1,1) = 'C' THEN 1 END) AS CONTROL_CUSTOMERS,
    COUNT(CASE WHEN SUBSTR(activity_code,1,1) = 'G' THEN 1 END) AS GLOBAL_HOLDOUT_CUSTOMERS
FROM "WUDNA"."SUMMARY_GEN"."WUDNA_SOLICITATION_HISTORY_VW"
WHERE 
      UPPER(CAMPAIGN_DESC) NOT LIKE 'TEST%'
  AND UPPER(CAMPAIGN_DESC) NOT LIKE '%UNKNOWN%'
  AND UPPER(CAMPAIGN_DESC) NOT LIKE '%RCVX%'
  AND DATE(RELEASE_2_VENDOR_DATE) >= '2026-01-01'
  AND DATE(RELEASE_2_VENDOR_DATE) < DATE_TRUNC('MONTH', CURRENT_DATE())
GROUP BY 
    all;

CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_EMAIL_SMS_WH_AGG AS 
select 
    CAMPAIGN_NAME,
    CAMPAIGN_DATE,
    SUM(TEST_CUSTOMERS) AS TOTAL_TEST_CUSTOMERS,
    SUM(CONTROL_CUSTOMERS) AS TOTAL_CONTROL_CUSTOMERS,
    SUM(GLOBAL_HOLDOUT_CUSTOMERS) AS TOTAL_GLOBAL_HOLDOUT_CUSTOMERS
FROM  AM_ONE_STOP_CAM_TRACKER_EMAIL_SMS_WH_CUST_LEVEL
    GROUP BY ALL;


CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_APP_TEST_CUST_LEVEL AS 
    select
	case when length(A.CUSTOMER_KEY) =19 then A.CUSTOMER_KEY else B.CUSTOMER_KEY end as CUSTOMER_KEY,
    UPPER(A.CAMPAIGN_CANVAS_NAME) as CAMPAIGN_NAME,
    case when substr(activity_code,3,1)='P' AND push_sent_date IS NOT NULL then push_sent_date
    when substr(activity_code,3,1)='I' AND inappmsg_viewed_date IS NOT NULL then inappmsg_viewed_date
    when substr(activity_code,3,1)='C' AND cc_sent_date IS NOT NULL then cc_sent_date
    ELSE TO_DATE('2099-01-01') -- SETTING AN ABSURD DATE SO THAT NO TXN DATA GETS JOINEDÂ 
    END AS CAMPAIGN_DATE,
    'TEST_CUSTS' as TEST_FLAG-- creating one column  from all other event type date columns
from 
    SUMMARY_GEN.BRAZE_SUMMARY_VW A
Left Join "WUDNA"."SUMMARY_GEN"."WUDNA_ACCOUNT_MASTER_VW" B on A.CUSTOMER_KEY = B.CUSTOMER_UMN	
where 
    A.CUSTOMER_KEY is not null 
	and B.CUSTOMER_KEY is not null
    and to_date(CAMPAIGN_DATE) not like '2099-01-01' 
    AND to_date(CAMPAIGN_DATE) >= '2025-02-01'
    and to_date(CAMPAIGN_DATE) < DATE_TRUNC('MONTH', CURRENT_DATE()) -- Change the date every month refresh--changed to may 2025--PK
    and TYPE='CAMPAIGN' 
    and Activity_code like 'S%'  
    and regexp_substr(B.customer_key,'[a-zA-Z]') is null
	and length(A.customer_key) in (9,19)
    AND not upper(CAMPAIGN_CANVAS_NAME) ILIKE any ('TEST%','%UNKNOWN%','%RCVX%')
    AND DATE(CAMPAIGN_DATE) >= '2025-01-01'
    ;
    
CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_APP_TEST_AGG AS 
SELECT
CAMPAIGN_NAME,
CAMPAIGN_DATE,
TEST_CUSTOMERS,
COUNT(DISTINCT CUSTOMER_KEY) AS TOTAL_TEST_CUSTOMERS,
    0 AS TOTAL_CONTROL_CUSTOMERS,
    0 AS TOTAL_GLOBAL_HOLDOUT_CUSTOMERS
FROM AM_ONE_STOP_CAM_TRACKER_APP_TEST_CUST_LEVEL
group by campaign_name, campaign_date;

CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_APP_GH_CUST_LEVEL AS 
select 
    UPPER(substr(campaign_canvas_name,4,len(campaign_canvas_name))) as CAMPAIGN_NAME,
    case when length(A.CUSTOMER_KEY) =19 then A.CUSTOMER_KEY
         else B.CUSTOMER_KEY
    end as CUSTOMER_KEY,
    CASE when substr(activity_code,3,1)='W' AND WEBHOOK_SENT_DATE IS NOT NULL then WEBHOOK_SENT_DATE
    ELSE TO_DATE('2099-01-01') -- SETTING AN ABSURD DATE SO THAT NO TXN DATA GETS JOINEDÂ 
    END AS CAMPAIGN_DATE,
    'GLOBAL_HOLD' as GLOBAL_HOLDOUT_CUSTOMERS-- creating one column  from all other event type date columns
from 
    SUMMARY_GEN.BRAZE_SUMMARY_VW A  
Left Join "WUDNA"."SUMMARY_GEN"."WUDNA_ACCOUNT_MASTER_VW" B on A.CUSTOMER_KEY = B.CUSTOMER_UMN
where 
    A.CUSTOMER_KEY is not null 
	and B.CUSTOMER_KEY is not null
    and to_date(CAMPAIGN_DATE) not like '2099-01-01'
    AND to_date(CAMPAIGN_DATE) >= '2025-02-01' -- Change the date every month refresh--changed to may 2025--PK
    and to_date(CAMPAIGN_DATE) < DATE_TRUNC('MONTH', CURRENT_DATE())
    AND TYPE='CAMPAIGN' 
    and Activity_code like 'G%'
    and regexp_substr(B.customer_key,'[a-zA-Z]') is null
	and length(A.customer_key) in (9,19)
    AND not upper(CAMPAIGN_CANVAS_NAME) ILIKE any ('TEST%','%UNKNOWN%','%RCVX%')
    AND DATE(CAMPAIGN_DATE) >= '2025-01-01';

CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_APP_GH_AGG AS 
    SELECT 
        CAMPAIGN_NAME,
        CAMPAIGN_DATE,
        GLOBAL_HOLDOUT_CUSTOMERS,
        0 AS TOTAL_TEST_CUSTOMERS,
        0 AS TOTAL_CONTROL_CUSTOMERS,
        COUNT(DISTINCT CUSTOMER_KEY) AS TOTAL_GLOBAL_CUSTOMERS        
    FROM AM_ONE_STOP_CAM_TRACKER_APP_GH_CUST_LEVEL
    GROUP BY ALL;

CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_APP_CH_CUST_LEVEL AS 
select 
            DISTINCT case when length(A.CUSTOMER_KEY) =19 then A.CUSTOMER_KEY else C.CUSTOMER_KEY
            end as CUSTOMER_KEY,
			UPPER(A.CAMPAIGN_CANVAS_NAME) as CAMPAIGN_NAME , 
			to_date(CAMPAIGN_CH_ENROLLED_DATE) CAMPAIGN_DATE
            'CONTROL_CUST' as CONTROL_HOLDOUT_CUSTOMERS
		from 
			SUMMARY_GEN.BRAZE_SUMMARY_VW A 
            left Join "WUDNA"."SUMMARY_GEN"."WUDNA_ACCOUNT_MASTER_VW" C on A.CUSTOMER_KEY = C.CUSTOMER_UMN
		WHERE 
		    C.CUSTOMER_KEY is not null and
		    TYPE='CAMPAIGN' and ACTIVITY_CODE like 'C%' 
			and to_date(CAMPAIGN_DATE) not like '2099-01-01'
            AND to_date(CAMPAIGN_DATE) >= '2025-02-01'
            and to_date(CAMPAIGN_DATE) < < DATE_TRUNC('MONTH', CURRENT_DATE()) -- Change the date every month refresh--changed date to May 2025--PK
			and length(A.customer_key) in (9,19)
        and regexp_substr(B.customer_key,'[a-zA-Z]') is null
	and length(A.customer_key) in (9,19)
    AND not upper(CAMPAIGN_CANVAS_NAME) ILIKE any ('TEST%','%UNKNOWN%','%RCVX%')
    AND DATE(CAMPAIGN_DATE) >= '2025-01-01';
;

CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_APP_CH_AGG AS 
    SELECT 
        CAMPAIGN_NAME,
        CAMPAIGN_DATE,
        CONTROL_HOLDOUT_CUSTOMERS,
        0 AS TOTAL_TEST_CUSTOMERS,
        COUNT(DISTINCT CUSTOMER_KEY) AS TOTAL_CONTROL_CUSTOMERS,
        0 AS TOTAL_GLOBAL_CUSTOMERS        
    FROM AM_ONE_STOP_CAM_TRACKER_APP_CH_CUST_LEVEL
    GROUP BY ALL;


    
CREATE OR REPLACE TABLE AM_ONE_STOP_CAM_TRACKER_CAM_UNION AS 
SELECT * FROM AM_ONE_STOP_CAM_TRACKER_APP_TEST_AGG
UNION
SELECT * FROM AM_ONE_STOP_CAM_TRACKER_APP_GH_AGG
