CREATE OR REPLACE TABLE CAR_921_US_IPF_MISSED_BEATS_CUST AS
 
WITH CAMP_ENGAGEMENT AS (
    SELECT
         CUSTOMER_KEY
        ,SUM(CASE WHEN SUBSTR(ACTIVITY_CODE,3,1) IN ('P') THEN (TOTAL_EMAILS_SENT) ELSE 1 END) AS Sent
        ,SUM(CASE WHEN EMAILS_UN_DELIVERED > 0 THEN 1 END)                                              AS COMMUNICATIONS_UNDELIVERED
        ,SUM(CASE WHEN EMAILS_OPENED_ATLEAST_ONCE_WITHIN_7_DAYS_OF_COMMUNICATION > 0 THEN 1 END)        AS Opened
        ,SUM(CASE WHEN EMAILS_WITH_ATLEAST_ONE_LINK_CLICK_WITHIN_7_DAYS_OF_COMMUNICATION > 0 THEN 1 END) AS Clicked
        ,SUM(CASE WHEN SUBSTR(ACTIVITY_CODE,3,1) = 'P'  AND EMAILS_OPENED_ATLEAST_ONCE_WITHIN_7_DAYS_OF_COMMUNICATION > 0 THEN 1 END) AS Push_Opened
        ,SUM(CASE WHEN SUBSTR(ACTIVITY_CODE,3,1) != 'P' AND EMAILS_WITH_ATLEAST_ONE_LINK_CLICK_WITHIN_7_DAYS_OF_COMMUNICATION > 0 THEN 1 END) AS WO_Push_Clicked
        ,NVL(Push_Opened,0) + NVL(WO_Push_Clicked,0) AS Opened_Clicked
        ,SUM(CASE WHEN RETAIL_TXNS_7DAYS > 0 THEN 1 END) AS RETAIL_TXNS7
        ,SUM(CASE WHEN DIGITAL_TXNS_7DAYS > 0 THEN 1 END) AS DIGITAL_TXNS7
        ,SUM(CASE WHEN TXNS_7DAYS > 0 THEN 1 END)         AS TOTAL_TXNS7
    FROM
        WUDNA.CEX_SANDBOX.SJ_BI_CAMPAIGN_WISE_EMAIL_COMMUNICATIONS_2_V2_MYWU_UPDATE_CUSTOMER_LEVEL
    WHERE
        DATE_TRUNC(MONTH, EVENT_CAPTURED_DT) >= DATEADD(MONTH, -12, DATE_TRUNC(MONTH, CURRENT_DATE))
        AND DATE_TRUNC(MONTH, EVENT_CAPTURED_DT) <= DATEADD(MONTH, -1, DATE_TRUNC(MONTH, CURRENT_DATE))
    GROUP BY ALL
),
 
CUST_LEVEL AS (
    SELECT
        
        CEM.SNDCUSTOMER_KEY AS GID,
        CUST.customer_umn AS UMN,  
        CUST.COUNTRY_CODE,
        
         
        
        CASE WHEN CEM.R12_APP_TXNS > 0 THEN 'Y' ELSE 'N' END AS APP_MARKETABLE_FLAG,
        CEM.EMAIL_MARKETABLE                                AS EMAIL_MARKETABLE_FLAG,

 
CASE
    WHEN CEM.EMAIL_MARKETABLE = 'Y' AND CEM.R12_APP_TXNS > 0 THEN 'EMAIL & APP'
    WHEN CEM.EMAIL_MARKETABLE = 'Y' AND CEM.R12_APP_TXNS = 0 THEN 'EMAIL only'
    WHEN CEM.EMAIL_MARKETABLE = 'N' AND CEM.R12_APP_TXNS > 0 THEN 'APP only'
    ELSE 'Neither EMAIL nor APP'
END AS MARKETABILITY,
 
        
        CUST.GLOBAL_HOLDOUT                              AS GLOBAL_HOLDOUT_FLAG,  
 
        --Loyalty split 
        CASE WHEN A.MYWU_STATUS = 'Non Member' THEN 'Non Member' ELSE 'Member' END AS LOYALTY_STATUS,
 
        -- IPF Missed Beats
        CASE
            WHEN CEM.BEATS IS NOT NULL THEN CEM.BEATS
            ELSE '<3 times transactor'
        END AS IPF_BEATS,
 
        CUST.PRFRD_LANGUAGE_CODE,
 
        CEM.MTH_YR
 
    FROM CEX_SANDBOX.YN_Va_kpi_2020_output_engagement_cust_level CEM
    LEFT JOIN WUDNA.CEX_SANDBOX.CUSTOMER_ENGAGEMENT_FRAMEWORK_CUST_LEVEL A
           ON A.SNDCUSTOMER_KEY = CEM.SNDCUSTOMER_KEY
          AND A.MTH_YR = CEM.MTH_YR
    LEFT JOIN WUDNA.SUMMARY_GEN.WUDNA_CUSTOMER_MASTER_VW CUST
           ON CEM.SNDCUSTOMER_KEY = CUST.CUSTOMER_KEY
    LEFT JOIN CAMP_ENGAGEMENT CAMP
           ON CEM.SNDCUSTOMER_KEY = CAMP.CUSTOMER_KEY
 
    WHERE
        CEM.MTH_YR          = DATEADD(MONTH, -1, DATE_TRUNC(MONTH, CURRENT_DATE))
        AND CEM.R12_TXNS     > 0
        AND CEM.R12_TXNS    IS NOT NULL
        AND CEM.COUNTRY_CODE = 'US'
        AND CEM.BEATS IS NOT NULL                           -- IPF missed beats customers only
        AND CEM.BEATS NOT IN ('Ahead Schedule', 'On Schedule', '<3 times transactor' ) AND
        (CEM.EMAIL_MARKETABLE = 'Y' OR CEM.R12_APP_TXNS > 0)
)
 
SELECT *
FROM CUST_LEVEL;

SELECT IPF_BEATS, count(distinct GID) FROM CAR_921_US_IPF_MISSED_BEATS_CUST group by 1;
SELECT MARKETABILITY, count(distinct GID) FROM CAR_921_US_IPF_MISSED_BEATS_CUST group by 1;

CREATE OR REPLACE TABLE CAR_921_US_IPF_BIRD_LIST AS
SELECT c.GID, c.UMN, c.country_code, c.app_marketable_flag, c.email_marketable_flag,c.marketability, c.global_holdout_flag,
c.loyalty_status, c.ipf_beats, c.prfrd_language_code 
FROM CEX_SANDBOX.CAR_921_US_IPF_MISSED_BEATS_CUST c
LEFT JOIN WUDNA.SUMMARY_GEN.WUDNA_BIRD_ALL_CONTACTS_VW b
       ON b.CUSTOMER_KEY = c.GID
WHERE b.CUSTOMER_KEY IS NOT NULL
and prfrd_language_code IN ('EN', 'ES')
;

SELECT * FROM CAR_921_US_IPF_BIRD_LIST;
