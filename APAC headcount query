CREATE OR REPLACE TABLE CAR_946_SG_TO_IN_Marketability AS
select *,
CASE 
           WHEN email_marketability_flag = 'Y' AND sms_marketability_flag = 'N' AND App_Marketability_Flag = 'N' THEN 'EMAIL_ONLY'
           WHEN email_marketability_flag = 'N' AND sms_marketability_flag = 'Y' AND App_Marketability_Flag = 'N' THEN 'SMS_ONLY'
           WHEN email_marketability_flag = 'N' AND sms_marketability_flag = 'N' AND App_Marketability_Flag = 'Y' THEN 'APP_ONLY'
           WHEN email_marketability_flag = 'Y' AND sms_marketability_flag = 'Y' AND App_Marketability_Flag = 'N' THEN 'EMAIL_SMS'
           WHEN email_marketability_flag = 'Y' AND sms_marketability_flag = 'N' AND App_Marketability_Flag = 'Y' THEN 'EMAIL_APP'
           WHEN email_marketability_flag = 'N' AND sms_marketability_flag = 'Y' AND App_Marketability_Flag = 'Y' THEN 'SMS_APP'
           WHEN email_marketability_flag = 'Y' AND sms_marketability_flag = 'Y' AND App_Marketability_Flag = 'Y' THEN 'EMAIL_SMS_APP'
           ELSE 'OTHERS'
       END AS MARKETING_COMBINATION,

       CASE WHEN email_marketability_flag = 'Y'
             OR sms_marketability_flag = 'Y'
             OR App_Marketability_Flag = 'Y' THEN 'Y' ELSE 'N' END AS MARKETABILITY_FLAG
    FROM(
SELECT DISTINCT
    b.SNDCUSTOMER_KEY AS gid_customer_key,
    cm.customer_umn    AS umn_customer_key,
    b.sndcountry_code,
    b.rcvcountry_code,
     cm.global_holdout,
    

    -- Marketability Flags
    CASE 
        WHEN cm.marketing_flag = 'Y' AND cm.email_address_on_file_flag = 'Y' AND cm.opt_email = 'I' THEN 'Y'
        ELSE 'N'
    END AS email_marketability_flag,

    CASE 
        WHEN cm.marketing_flag = 'Y' AND cm.mobile_number_on_file_flag = 'Y' AND cm.opt_sms = 'I' THEN 'Y'
        ELSE 'N'
    END AS sms_marketability_flag,

    CASE WHEN APP_TXNS > 0 THEN 'Y' ELSE 'N' END AS App_Marketability_Flag


FROM CAR_946_SG_TO_IN b
JOIN SUMMARY_GEN.WUDNA_CUSTOMER_MASTER_VW cm
  ON b.SNDCUSTOMER_KEY = cm.customer_key);


  SELECT 
    '@' || GID_CUSTOMER_KEY AS GID,
    '@' || UMN_CUSTOMER_KEY AS UMN,
    SNDCOUNTRY_CODE,
    EMAIL_MARKETABILITY_FLAG,
    SMS_MARKETABILITY_FLAG,
    APP_MARKETABILITY_FLAG,
    MARKETABILITY_FLAG,
    MARKETING_COMBINATION,
    global_holdout
FROM CAR_946_SG_TO_IN_Marketability
Order by GID;
