Simplified Approach
The idea: SQL does the heavy lifting of labeling each customer, Excel handles all the ranking, rates, and pivot analysis. Here's the lean script:
SQL — 3 clean steps, one output table
-- ============================================================
-- STEP 1: BASE TRANSACTIONS  (2024–2025, ME markets)
-- ============================================================
CREATE OR REPLACE TABLE CAR_861_BASE AS
SELECT
    sndcustomer_key,
    TXN_ID,
    DATE(rcvpaying_datetime)                        AS txn_date,
    DATE_TRUNC('MONTH', DATE(rcvpaying_datetime))   AS txn_month,
    sndcountry_code,
    rcvcountry_code,
    CONCAT(sndcountry_code,'-',rcvcountry_code)     AS corridor,
    CASE
        WHEN pricing_channel IN ('WEB','APP')       THEN 'DIGITAL'
        WHEN pricing_channel IN ('POS','AIR','TMT') THEN 'RETAIL'
        ELSE 'OTHERS'
    END AS channel_type
FROM WUDNA.SUMMARY_GEN.WUDNA_TXN_MASTER_ANALYTICS_VW
WHERE sndcountry_code IN ('AE','BH','JO','QA','SA','KW')
  AND AGENT_NAID NOT IN (
        'AEE29','JO999','JOD00','JO997','JO996','JOT44',
        'KWI85','KWR99','KWJ19','KWJ52',
        'QAU02','QAU01','QAQ96','QAQ25','QAH42','QAH01','QA999','QA997')
  AND DATE(rcvpaying_datetime) BETWEEN '2024-01-01' AND '2025-12-31';


-- ============================================================
-- STEP 2: MARKETABILITY FLAGS
-- ============================================================
CREATE OR REPLACE TABLE CAR_861_MKTBL AS
SELECT
    customer_key,
    global_holdout,
    CASE WHEN marketing_flag='Y' AND email_address_on_file_flag='Y' AND opt_email='I' THEN 'Y' ELSE 'N' END AS email_ok,
    CASE WHEN marketing_flag='Y' AND mobile_number_on_file_flag='Y' AND opt_sms='I'   THEN 'Y' ELSE 'N' END AS sms_ok
FROM WUDNA.SUMMARY_GEN.WUDNA_CUSTOMER_MASTER_VW
WHERE first_registration_date IS NOT NULL;


-- ============================================================
-- STEP 3: FINAL OUTPUT — One row per R2D converted customer
-- Conversion = first DIGITAL txn in a 2025 month,
--              AND had RETAIL in the prior 12 months (R2–R13 window)
-- ============================================================
CREATE OR REPLACE TABLE CAR_861_R2D_OUTPUT AS
WITH first_digital AS (
    -- First digital transaction month per customer, restricted to 2025
    SELECT sndcustomer_key,
           MIN(txn_month) AS first_digital_month
    FROM   CAR_861_BASE
    WHERE  channel_type = 'DIGITAL'
      AND  txn_month BETWEEN '2025-01-01' AND '2025-12-01'
    GROUP BY sndcustomer_key
),
had_retail_prior AS (
    -- Customers who had at least one retail txn in the 12 months before their first digital month
    SELECT DISTINCT b.sndcustomer_key
    FROM   CAR_861_BASE b
    JOIN   first_digital fd ON b.sndcustomer_key = fd.sndcustomer_key
    WHERE  b.channel_type = 'RETAIL'
      AND  b.txn_date >= DATEADD('MONTH', -12, fd.first_digital_month)
      AND  b.txn_date <  fd.first_digital_month
),
dominant_corridor AS (
    -- Most-used corridor per customer (by txn count, recency as tiebreak)
    SELECT sndcustomer_key, corridor, sndcountry_code, rcvcountry_code
    FROM (
        SELECT sndcustomer_key, corridor, sndcountry_code, rcvcountry_code,
               ROW_NUMBER() OVER (
                   PARTITION BY sndcustomer_key
                   ORDER BY COUNT(DISTINCT txn_id) DESC, MAX(txn_date) DESC
               ) AS rnk
        FROM CAR_861_BASE
        GROUP BY sndcustomer_key, corridor, sndcountry_code, rcvcountry_code
    )
    WHERE rnk = 1
)
SELECT
    fd.sndcustomer_key,
    TO_CHAR(fd.first_digital_month, 'YYYY-MM')  AS conversion_month,
    dc.sndcountry_code                           AS send_market,
    dc.corridor,
    dc.rcvcountry_code                           AS receive_country,
    -- Marketability
    mk.global_holdout,
    mk.email_ok,
    mk.sms_ok,
    CASE WHEN mk.email_ok='Y' OR mk.sms_ok='Y'  THEN 'Y' ELSE 'N' END AS any_marketable,
    CASE
        WHEN mk.email_ok='Y' AND mk.sms_ok='Y'  THEN 'EMAIL+SMS'
        WHEN mk.email_ok='Y'                     THEN 'EMAIL_ONLY'
        WHEN mk.sms_ok  ='Y'                     THEN 'SMS_ONLY'
        ELSE 'NONE'
    END AS marketability_segment
FROM   first_digital   fd
JOIN   had_retail_prior r  ON fd.sndcustomer_key = r.sndcustomer_key
JOIN   dominant_corridor dc ON fd.sndcustomer_key = dc.sndcustomer_key
LEFT JOIN CAR_861_MKTBL mk  ON fd.sndcustomer_key = mk.customer_key;
Pull CAR_861_R2D_OUTPUT into Excel. That's your only export.
