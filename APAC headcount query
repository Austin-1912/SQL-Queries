SUM(a.RETAIL_TXNS) AS RETAIL_TXNS,
SUM(a.AIR_TXNS) AS AIR_TXNS,
SUM(a.DIGITAL_TXNS) AS DIGITAL_TXNS,
SUM(a.APP_TXNS) AS APP_TXNS,
SUM(a.POS_TXNS) AS POS_TXNS,
SUM(a.TEST_REDEEM_ONLY_DELIVERED) AS TEST_REDEEM_ONLY_DELIVERED,
SUM(a.TEST_MEMBER_ONLY_DELIVERED) AS TEST_MEMBER_ONLY_DELIVERED,
SUM(a.TEST_ENROLLED_ONLY_DELIVERED) AS TEST_ENROLLED_ONLY_DELIVERED,
SUM(a.TEST_NON_MEMBER_ONLY_DELIVERED) AS TEST_NON_MEMBER_ONLY_DELIVERED,
