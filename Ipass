-- ============================================================================
-- PPT AND RPT DOMINANT BUCKETS - APN VS NON-APN SENDERS
-- ============================================================================
-- Using the same logic as CAM_1746_FINAL_APN_PROFILING
-- Dominant bucket = the bucket with the most transactions for each customer
-- ============================================================================

-- ============================================================================
-- STEP 1: CREATE BASE TABLE FOR ALL CUSTOMERS (IF NOT EXISTS)
-- ============================================================================
-- Skip this if CAM_1746_Cust_Base already exists
-- This is the same as your existing code

-- Already exists from your script above


-- ============================================================================
-- STEP 2: DOMINANT PPT BUCKET - APN SENDERS
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_APN_DOMINANT_PPT_BUCKET AS
SELECT *
FROM (
    SELECT
        SNDCUSTOMER_KEY,
        PPT_bucket,
        COUNT(DISTINCT TXN_ID) AS txn_count,
        SUM(SNDPRINCIPAL_USD) AS total_principal_usd,
        ROW_NUMBER() OVER (
            PARTITION BY SNDCUSTOMER_KEY
            ORDER BY COUNT(DISTINCT TXN_ID) DESC, MAX(txn_dt) DESC
        ) AS rnk
    FROM CAM_1746_Cust_Base
    WHERE SNDCUSTOMER_KEY IN (
        -- APN Senders: Customers with at least 1 ACCOUNT transaction
        SELECT DISTINCT SNDCUSTOMER_KEY
        FROM CAM_1746_Cust_Base
        WHERE PAYOUT_TYPE = 'ACCOUNT'
    )
    GROUP BY SNDCUSTOMER_KEY, PPT_bucket
)
WHERE rnk = 1;

SELECT COUNT(DISTINCT SNDCUSTOMER_KEY) FROM CAM_1746_APN_DOMINANT_PPT_BUCKET;


-- ============================================================================
-- STEP 3: DOMINANT RPT BUCKET - APN SENDERS
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_APN_DOMINANT_RPT_BUCKET AS
SELECT *
FROM (
    SELECT
        SNDCUSTOMER_KEY,
        RPT_bucket,
        COUNT(DISTINCT TXN_ID) AS txn_count,
        SUM(REVENUE) AS total_revenue,
        ROW_NUMBER() OVER (
            PARTITION BY SNDCUSTOMER_KEY
            ORDER BY COUNT(DISTINCT TXN_ID) DESC, MAX(txn_dt) DESC
        ) AS rnk
    FROM CAM_1746_Cust_Base
    WHERE SNDCUSTOMER_KEY IN (
        -- APN Senders: Customers with at least 1 ACCOUNT transaction
        SELECT DISTINCT SNDCUSTOMER_KEY
        FROM CAM_1746_Cust_Base
        WHERE PAYOUT_TYPE = 'ACCOUNT'
    )
    GROUP BY SNDCUSTOMER_KEY, RPT_bucket
)
WHERE rnk = 1;

SELECT COUNT(DISTINCT SNDCUSTOMER_KEY) FROM CAM_1746_APN_DOMINANT_RPT_BUCKET;


-- ============================================================================
-- STEP 4: DOMINANT PPT BUCKET - NON-APN SENDERS
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_NON_APN_DOMINANT_PPT_BUCKET AS
SELECT *
FROM (
    SELECT
        SNDCUSTOMER_KEY,
        PPT_bucket,
        COUNT(DISTINCT TXN_ID) AS txn_count,
        SUM(SNDPRINCIPAL_USD) AS total_principal_usd,
        ROW_NUMBER() OVER (
            PARTITION BY SNDCUSTOMER_KEY
            ORDER BY COUNT(DISTINCT TXN_ID) DESC, MAX(txn_dt) DESC
        ) AS rnk
    FROM CAM_1746_Cust_Base
    WHERE SNDCUSTOMER_KEY NOT IN (
        -- NON-APN Senders: Customers with NO ACCOUNT transactions
        SELECT DISTINCT SNDCUSTOMER_KEY
        FROM CAM_1746_Cust_Base
        WHERE PAYOUT_TYPE = 'ACCOUNT'
    )
    GROUP BY SNDCUSTOMER_KEY, PPT_bucket
)
WHERE rnk = 1;

SELECT COUNT(DISTINCT SNDCUSTOMER_KEY) FROM CAM_1746_NON_APN_DOMINANT_PPT_BUCKET;


-- ============================================================================
-- STEP 5: DOMINANT RPT BUCKET - NON-APN SENDERS
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_NON_APN_DOMINANT_RPT_BUCKET AS
SELECT *
FROM (
    SELECT
        SNDCUSTOMER_KEY,
        RPT_bucket,
        COUNT(DISTINCT TXN_ID) AS txn_count,
        SUM(REVENUE) AS total_revenue,
        ROW_NUMBER() OVER (
            PARTITION BY SNDCUSTOMER_KEY
            ORDER BY COUNT(DISTINCT TXN_ID) DESC, MAX(txn_dt) DESC
        ) AS rnk
    FROM CAM_1746_Cust_Base
    WHERE SNDCUSTOMER_KEY NOT IN (
        -- NON-APN Senders: Customers with NO ACCOUNT transactions
        SELECT DISTINCT SNDCUSTOMER_KEY
        FROM CAM_1746_Cust_Base
        WHERE PAYOUT_TYPE = 'ACCOUNT'
    )
    GROUP BY SNDCUSTOMER_KEY, RPT_bucket
)
WHERE rnk = 1;

SELECT COUNT(DISTINCT SNDCUSTOMER_KEY) FROM CAM_1746_NON_APN_DOMINANT_RPT_BUCKET;


-- ============================================================================
-- STEP 6: COMBINED PPT x RPT DISTRIBUTION - APN SENDERS
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_APN_PPT_RPT_DISTRIBUTION AS
SELECT
    ppt.PPT_bucket AS DOMINANT_PPT_BUCKET,
    rpt.RPT_bucket AS DOMINANT_RPT_BUCKET,
    COUNT(DISTINCT ppt.SNDCUSTOMER_KEY) AS CUSTOMER_COUNT,
    SUM(ppt.txn_count) AS TOTAL_PPT_TXNS,
    SUM(rpt.txn_count) AS TOTAL_RPT_TXNS,
    SUM(ppt.total_principal_usd) AS TOTAL_PRINCIPAL,
    SUM(rpt.total_revenue) AS TOTAL_REVENUE
FROM CAM_1746_APN_DOMINANT_PPT_BUCKET ppt
INNER JOIN CAM_1746_APN_DOMINANT_RPT_BUCKET rpt
    ON ppt.SNDCUSTOMER_KEY = rpt.SNDCUSTOMER_KEY
GROUP BY ppt.PPT_bucket, rpt.RPT_bucket
ORDER BY ppt.PPT_bucket, rpt.RPT_bucket;

-- View results
SELECT * FROM CAM_1746_APN_PPT_RPT_DISTRIBUTION;


-- ============================================================================
-- STEP 7: COMBINED PPT x RPT DISTRIBUTION - NON-APN SENDERS
-- ============================================================================

CREATE OR REPLACE TABLE CAM_1746_NON_APN_PPT_RPT_DISTRIBUTION AS
SELECT
    ppt.PPT_bucket AS DOMINANT_PPT_BUCKET,
    rpt.RPT_bucket AS DOMINANT_RPT_BUCKET,
    COUNT(DISTINCT ppt.SNDCUSTOMER_KEY) AS CUSTOMER_COUNT,
    SUM(ppt.txn_count) AS TOTAL_PPT_TXNS,
    SUM(rpt.txn_count) AS TOTAL_RPT_TXNS,
    SUM(ppt.total_principal_usd) AS TOTAL_PRINCIPAL,
    SUM(rpt.total_revenue) AS TOTAL_REVENUE
FROM CAM_1746_NON_APN_DOMINANT_PPT_BUCKET ppt
INNER JOIN CAM_1746_NON_APN_DOMINANT_RPT_BUCKET rpt
    ON ppt.SNDCUSTOMER_KEY = rpt.SNDCUSTOMER_KEY
GROUP BY ppt.PPT_bucket, rpt.RPT_bucket
ORDER BY ppt.PPT_bucket, rpt.RPT_bucket;

-- View results
SELECT * FROM CAM_1746_NON_APN_PPT_RPT_DISTRIBUTION;


