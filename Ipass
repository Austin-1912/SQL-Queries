    COUNT(DISTINCT SNDCUSTOMER_KEY) AS customer_count
FROM CAM_1746_APN_DOMINANT_PPT_BUCKET

UNION ALL

SELECT
    'APN SENDERS - RPT' AS segment,
    COUNT(DISTINCT SNDCUSTOMER_KEY) AS customer_count
FROM CAM_1746_APN_DOMINANT_RPT_BUCKET

UNION ALL

SELECT
    'NON-APN SENDERS - PPT' AS segment,
    COUNT(DISTINCT SNDCUSTOMER_KEY) AS customer_count
FROM CAM_1746_NON_APN_DOMINANT_PPT_BUCKET

UNION ALL

SELECT
    'NON-APN SENDERS - RPT' AS segment,
    COUNT(DISTINCT SNDCUSTOMER_KEY) AS customer_count
FROM CAM_1746_NON_APN_DOMINANT_RPT_BUCKET;


-- Check PPT bucket distribution - APN vs NON-APN
SELECT 
    'APN SENDERS' AS segment,
    PPT_bucket,
    COUNT(DISTINCT SNDCUSTOMER_KEY) AS customer_count,
    ROUND(COUNT(DISTINCT SNDCUSTOMER_KEY) * 100.0 / SUM(COUNT(DISTINCT SNDCUSTOMER_KEY)) OVER (PARTITION BY 'APN SENDERS'), 2) AS pct
FROM CAM_1746_APN_DOMINANT_PPT_BUCKET
GROUP BY PPT_bucket

UNION ALL

SELECT 
    'NON-APN SENDERS' AS segment,
    PPT_bucket,
    COUNT(DISTINCT SNDCUSTOMER_KEY) AS customer_count,
    ROUND(COUNT(DISTINCT SNDCUSTOMER_KEY) * 100.0 / SUM(COUNT(DISTINCT SNDCUSTOMER_KEY)) OVER (PARTITION BY 'NON-APN SENDERS'), 2) AS pct
FROM CAM_1746_NON_APN_DOMINANT_PPT_BUCKET
GROUP BY PPT_bucket

ORDER BY segment, PPT_bucket;


-- Check RPT bucket distribution - APN vs NON-APN
SELECT 
    'APN SENDERS' AS segment,
    RPT_bucket,
    COUNT(DISTINCT SNDCUSTOMER_KEY) AS customer_count,
    ROUND(COUNT(DISTINCT SNDCUSTOMER_KEY) * 100.0 / SUM(COUNT(DISTINCT SNDCUSTOMER_KEY)) OVER (PARTITION BY 'APN SENDERS'), 2) AS pct
FROM CAM_1746_APN_DOMINANT_RPT_BUCKET
GROUP BY RPT_bucket

UNION ALL

SELECT 
    'NON-APN SENDERS' AS segment,
    RPT_bucket,
    COUNT(DISTINCT SNDCUSTOMER_KEY) AS customer_count,
    ROUND(COUNT(DISTINCT SNDCUSTOMER_KEY) * 100.0 / SUM(COUNT(DISTINCT SNDCUSTOMER_KEY)) OVER (PARTITION BY 'NON-APN SENDERS'), 2) AS pct
FROM CAM_1746_NON_APN_DOMINANT_RPT_BUCKET
GROUP BY RPT_bucket

ORDER BY segment, RPT_bucket;


