-- Overall statistics comparison
SELECT
    'APN SENDERS' AS segment,
    COUNT(DISTINCT ppt.SNDCUSTOMER_KEY) AS total_customers,
    COUNT(DISTINCT CASE WHEN ppt.PPT_bucket IN ('A.<$100', 'B.$100-$500') THEN ppt.SNDCUSTOMER_KEY END) AS low_ppt_customers,
    COUNT(DISTINCT CASE WHEN ppt.PPT_bucket IN ('E.$2,000-$5,000', 'F.$5,000+') THEN ppt.SNDCUSTOMER_KEY END) AS high_ppt_customers,
    COUNT(DISTINCT CASE WHEN rpt.RPT_bucket IN ('A.<$5', 'B.$5-$10') THEN rpt.SNDCUSTOMER_KEY END) AS low_rpt_customers,
    COUNT(DISTINCT CASE WHEN rpt.RPT_bucket IN ('F.$40-$80', 'G.$80+') THEN rpt.SNDCUSTOMER_KEY END) AS high_rpt_customers
FROM CAM_1746_APN_DOMINANT_PPT_BUCKET ppt
INNER JOIN CAM_1746_APN_DOMINANT_RPT_BUCKET rpt
    ON ppt.SNDCUSTOMER_KEY = rpt.SNDCUSTOMER_KEY

UNION ALL

SELECT
    'NON-APN SENDERS' AS segment,
    COUNT(DISTINCT ppt.SNDCUSTOMER_KEY) AS total_customers,
    COUNT(DISTINCT CASE WHEN ppt.PPT_bucket IN ('A.<$100', 'B.$100-$500') THEN ppt.SNDCUSTOMER_KEY END) AS low_ppt_customers,
    COUNT(DISTINCT CASE WHEN ppt.PPT_bucket IN ('E.$2,000-$5,000', 'F.$5,000+') THEN ppt.SNDCUSTOMER_KEY END) AS high_ppt_customers,
    COUNT(DISTINCT CASE WHEN rpt.RPT_bucket IN ('A.<$5', 'B.$5-$10') THEN rpt.SNDCUSTOMER_KEY END) AS low_rpt_customers,
    COUNT(DISTINCT CASE WHEN rpt.RPT_bucket IN ('F.$40-$80', 'G.$80+') THEN rpt.SNDCUSTOMER_KEY END) AS high_rpt_customers
